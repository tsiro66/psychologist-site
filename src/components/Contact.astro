---
import Button from "./Button.astro";

const contactInfo = [
  {
    icon: "phone",
    label: "Τηλέφωνο",
    value: "+30 210 123 4567",
    href: "tel:+302101234567",
  },
  {
    icon: "email",
    label: "Email",
    value: "info@kritikoukaterina.gr",
    href: "mailto:info@kritikoukaterina.gr",
  },
  {
    icon: "location",
    label: "Διεύθυνση",
    value: "Βύρωνος 13 Ηλιούπολη (2ος όροφος, εντός του εμπορικού κέντρου)",
    href: "https://maps.google.com",
  },
  {
    icon: "clock",
    label: "Ωράριο",
    value: "Δευ - Παρ: 09:00 - 20:00",
    href: null,
  },
];
---

<section id="contact" class="relative py-28 px-6 bg-zinc-50">
  <div class="max-w-6xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <span
        class="inline-block text-sm tracking-widest uppercase text-lime-600 font-semibold mb-4 contact-reveal opacity-0"
      >
        Επικοινωνία
      </span>
      <h2
        class="text-4xl md:text-5xl font-serif text-neutral-950 leading-tight contact-reveal opacity-0"
        style="animation-delay: 0.1s;"
      >
        Ας <span class="text-violet-600 italic">μιλήσουμε</span>
      </h2>
      <p
        class="mt-5 text-neutral-500 max-w-2xl mx-auto leading-relaxed contact-reveal opacity-0"
        style="animation-delay: 0.2s;"
      >
        Κάνε το πρώτο βήμα σήμερα. Στείλε μας μήνυμα ή κάλεσέ μας για να
        κλείσεις τη δωρεάν συνεδρία γνωριμίας σου.
      </p>
    </div>

    <!-- Two-column layout -->
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10">
      <!-- Contact Form -->
      <div
        class="lg:col-span-3 bg-white p-8 md:p-10 border border-stone-200 shadow-xl shadow-stone-200/60 contact-reveal opacity-0"
        style="animation-delay: 0.25s;"
      >
        <form class="space-y-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label
                for="name"
                class="block text-sm font-medium text-neutral-950 mb-2"
              >
                Όνομα
              </label>
              <input
                type="text"
                id="name"
                name="name"
                placeholder="Το όνομά σου"
                class="w-full px-4 py-3 bg-white border border-stone-200 text-sm text-neutral-950 placeholder:text-neutral-400 outline-none focus:border-lime-400 focus:ring-2 focus:ring-lime-100 transition-all duration-300"
              />
            </div>
            <div>
              <label
                for="email"
                class="block text-sm font-medium text-neutral-950 mb-2"
              >
                Email
              </label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="Το email σου"
                class="w-full px-4 py-3 bg-white border border-stone-200 text-sm text-neutral-950 placeholder:text-neutral-400 outline-none focus:border-lime-400 focus:ring-2 focus:ring-lime-100 transition-all duration-300"
              />
            </div>
          </div>

          <div>
            <label
              for="phone"
              class="block text-sm font-medium text-neutral-950 mb-2"
            >
              Τηλέφωνο
              <span class="text-neutral-400 font-normal">(προαιρετικό)</span>
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              placeholder="Το τηλέφωνό σου"
              class="w-full px-4 py-3 bg-white border border-stone-200 text-sm text-neutral-950 placeholder:text-neutral-400 outline-none focus:border-lime-400 focus:ring-2 focus:ring-lime-100 transition-all duration-300"
            />
          </div>

          <div>
            <label
              for="service"
              class="block text-sm font-medium text-neutral-950 mb-2"
            >
              Υπηρεσία ενδιαφέροντος
            </label>
            <select
              id="service"
              name="service"
              class="w-full px-4 py-3 bg-white border border-stone-200 text-sm text-neutral-950 outline-none focus:border-lime-400 focus:ring-2 focus:ring-lime-100 transition-all duration-300 appearance-none"
              style="background-image: url('data:image/svg+xml;charset=UTF-8,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 width=%2716%27 height=%2716%27 fill=%27none%27 viewBox=%270 0 24 24%27 stroke=%27%23a3a3a3%27 stroke-width=%272%27%3E%3Cpath stroke-linecap=%27round%27 stroke-linejoin=%27round%27 d=%27m19.5 8.25-7.5 7.5-7.5-7.5%27/%3E%3C/svg%3E'); background-repeat: no-repeat; background-position: right 1rem center;"
            >
              <option value="" disabled selected>Επίλεξε υπηρεσία</option>
              <option value="individual">Ατομική Ψυχοθεραπεία</option>
              <option value="couple">Θεραπεία Ζεύγους</option>
              <option value="child">Παιδοψυχολογία</option>
              <option value="anxiety">Διαχείριση Άγχους</option>
              <option value="group">Ομαδική Θεραπεία</option>
              <option value="parent">Συμβουλευτική Γονέων</option>
            </select>
          </div>

          <div>
            <label
              for="message"
              class="block text-sm font-medium text-neutral-950 mb-2"
            >
              Μήνυμα
            </label>
            <textarea
              id="message"
              name="message"
              rows="4"
              placeholder="Πες μας λίγα λόγια για εσένα και τι σε απασχολεί..."
              class="w-full px-4 py-3 bg-white border border-stone-200 text-sm text-neutral-950 placeholder:text-neutral-400 outline-none focus:border-lime-400 focus:ring-2 focus:ring-lime-100 transition-all duration-300 resize-none"
            ></textarea>
          </div>

          <Button variant="primary" className="w-full text-center justify-center py-3.5">
            Αποστολή μηνύματος
          </Button>
        </form>
      </div>

      <!-- Contact Info Sidebar -->
      <div class="lg:col-span-2 flex flex-col gap-5">
        {
          contactInfo.map((info, i) => (
            <a
              href={info.href ?? undefined}
              target={info.href?.startsWith("http") ? "_blank" : undefined}
              rel={info.href?.startsWith("http") ? "noopener noreferrer" : undefined}
              class:list={[
                "group flex items-start gap-5 p-6 border border-stone-200 bg-white shadow-md shadow-stone-200/50 transition-all duration-500 hover:border-lime-300 hover:shadow-lg hover:shadow-lime-100/60 contact-reveal opacity-0",
                !info.href && "pointer-events-none",
              ]}
              style={`animation-delay: ${0.3 + i * 0.1}s;`}
            >
              <div class="w-11 h-11 rounded-xl bg-violet-100 flex items-center justify-center flex-shrink-0 group-hover:bg-lime-100 transition-colors duration-500">
                {info.icon === "phone" && (
                  <svg class="w-5 h-5 text-violet-500 group-hover:text-lime-600 transition-colors duration-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                  </svg>
                )}
                {info.icon === "email" && (
                  <svg class="w-5 h-5 text-violet-500 group-hover:text-lime-600 transition-colors duration-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                  </svg>
                )}
                {info.icon === "location" && (
                  <svg class="w-5 h-5 text-violet-500 group-hover:text-lime-600 transition-colors duration-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                  </svg>
                )}
                {info.icon === "clock" && (
                  <svg class="w-5 h-5 text-violet-500 group-hover:text-lime-600 transition-colors duration-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                  </svg>
                )}
              </div>
              <div>
                <span class="block text-xs text-neutral-400 uppercase tracking-wider mb-1">
                  {info.label}
                </span>
                <span class="text-sm font-medium text-neutral-950">
                  {info.value}
                </span>
              </div>
            </a>
          ))
        }

        <!-- Social / CTA card -->
        <div
          class="p-6 bg-gradient-to-br from-violet-600 to-violet-800 text-white shadow-xl shadow-violet-300/40 contact-reveal opacity-0"
          style="animation-delay: 0.75s;"
        >
          <h3 class="font-semibold text-lg mb-2">Δωρεάν συνεδρία γνωριμίας</h3>
          <p class="text-sm text-violet-200 leading-relaxed">
            Κάνε το πρώτο βήμα χωρίς δέσμευση. Κλείσε μια δωρεάν συνεδρία 20
            λεπτών για να γνωριστούμε.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes contactReveal {
    from {
      filter: blur(8px);
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      filter: blur(0);
      opacity: 1;
      transform: translateY(0);
    }
  }

  .contact-reveal.is-visible {
    animation: contactReveal 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
</style>

<script>
  const contactObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          contactObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll(".contact-reveal").forEach((el) => {
    contactObserver.observe(el);
  });
</script>
